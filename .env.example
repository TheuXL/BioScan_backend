# Copiar para .env e preencher (nunca commitar .env)

PORT=3000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/bio_scan_db

# Open-Meteo — cache Mongo (forecast, archive, air-quality) se Mongo ligado
# OPENMETEO_PROXY_RECONCILIATION_MODE=hybrid_ttl
# OPENMETEO_PROXY_TTL_SEC=1800

# USGS Earthquakes — cache Mongo (GET /api/earthquakes, /feed/:window) se Mongo ligado
# USGS_PROXY_RECONCILIATION_MODE=hybrid_ttl
# USGS_PROXY_TTL_SEC=900

# NASA FIRMS — https://firms.modaps.eosdis.nasa.gov/api/map_key
MAP_KEY=

# OpenAQ v3 — https://explore.openaq.org/register
OPENAQ_API_KEY=
# Cache MongoDB em GET /api/openaq/locations (requer MongoDB ligado): delta | snapshot | hybrid_ttl
# OPENAQ_LOCATIONS_RECONCILIATION_MODE=hybrid_ttl
# OPENAQ_LOCATIONS_TTL_SEC=3600
# Demais rotas OpenAQ v3 (/locations/:id, /latest, /countries, /parameters) — mesmo padrão de reconciliação
# OPENAQ_PROXY_RECONCILIATION_MODE=hybrid_ttl
# OPENAQ_PROXY_TTL_SEC=3600

# NASA EONET v2.1 — proxy sem API key (eventos, categorias, fontes, camadas)
# EONET_PROXY_RECONCILIATION_MODE=hybrid_ttl
# EONET_PROXY_TTL_SEC=1800

# EPA Ocean Pollution (R9 ArcGIS) — metadata + query GeoJSON
# OCEAN_POLLUTION_PROXY_RECONCILIATION_MODE=hybrid_ttl
# OCEAN_POLLUTION_PROXY_TTL_SEC=3600

# GFW Data API — https://data-api.globalforestwatch.org/ (Authentication)
# Obrigatório para GET .../api/deforestation/dataset/.../query/json
GFW_API_KEY=
# Cache Mongo (ping, datasets, fields, query/json): delta | snapshot | hybrid_ttl
# GFW_PROXY_RECONCILIATION_MODE=hybrid_ttl
# GFW_PROXY_TTL_SEC=3600
# Opcional: cabeçalho Origin nas chamadas com chave (tem de constar nos "domains" da key na GFW).
# Dev: omitir ou http://localhost | Produção: https://api.teudominio.com
# GFW_API_ORIGIN=http://localhost

# Nível do mar — ver NasaSeaLevel/README.md
# SEA_LEVEL_DATA_URL=
# SEA_LEVEL_ALLOW_BUNDLED_FALLBACK=

# Espécies em risco — GBIF (/api/extinction), sem chave
# EXTINCTION_GBIF_MAX_RECORDS_PER_SYNC=600
# EXTINCTION_GBIF_PAGE_SIZE=300
# EXTINCTION_GBIF_IUCN_CATEGORIES=CR,EN,VU
